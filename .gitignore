# Build / cache
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.cache/
.jax_cache/

# Local data dumps
*.npz
*.json.gz

# Scratch / one-off analysis scripts (named _tmp_* by convention; deleted after use)
tools/_tmp_*.py

# Working artifacts (specs, plans, theory drafts) stay local — see CLAUDE.md.
docs/

# results/ — track curated text artifacts (metrics, csvs, figures, tables,
# writeup); ignore heavy regeneratable blobs.
results/**/trained_*.json
# 6_dataset_compression checkpoints are load-bearing (the codec's decoder
# needs the basis file, and its size is part of the published byte
# accounting) — track them despite the blanket rule above.
!results/training/6_dataset_compression/**/trained_*.json
results/**/loss_history/
results/**/run.log
results/**/failures/
# per-step block-emergence training snapshots (bulky raw blobs; the curated
# block_emergence_spectrogram.json + figures are tracked instead)
results/**/checkpoints/
# raw XLA profiler traces (bulky protobuf; the curated profile.json + report.md
# + figures alongside them carry the findings)
results/**/trace/
results/**/block_emergence*/loss_history.json

# Local virtualenv (created for runs; not part of the repo)
.venv/
