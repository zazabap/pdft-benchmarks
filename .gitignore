# Build / cache
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.cache/
.jax_cache/

# Local data dumps
*.npz
*.json.gz

# Scratch / one-off analysis scripts (named _tmp_* by convention; deleted after use)
tools/_tmp_*.py

